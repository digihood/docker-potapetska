#: src/Skip_Rows.php:87
msgid "You must set a table and DB id before skipping a row."
msgstr "Pro přeskočení řádku musíte zvolit tabulku a databázové id."

#. Description of the plugin
#: go-live-update-urls.php
msgid "Updates every URL on your site when going live or changing domains."
msgstr "Upraví každou URL na vašem webu při přechodu do ostrého provozu nebo při změně domény."

#: src/Core.php:136
msgid "Settings"
msgstr "Nastavení"

#: src/Core.php:138
msgid "Go PRO"
msgstr "Přejít na PRO"

#: src/Admin.php:181
msgid "These tables are safe to update."
msgstr "Úprava těchto tabulek je bezpečná."

#: src/Admin.php:144
msgid "Replaces all occurrences in the entire database of the Old URL with a New URL."
msgstr "Nahrazuje v databázi všechny výskyty staré adresy za novou adresu."

#: src/Admin.php:99
msgid "You must select tables and fill out both the Old URL and New URL to update urls!"
msgstr "Pro úpravu musíte zaškrtnout tabulky a vyplnit starou i novou adresu!"

